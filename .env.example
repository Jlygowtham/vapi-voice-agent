# Vapi Credentials
# ----------------
# 1. Public Key (Frontend) - Found in Vapi Dashboard > Account Settings
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here

# 2. Assistant ID - The ID of your configured voice agent (6cee1a72-ba5c-4239-a8d4-a0cd30b2b547)
NEXT_PUBLIC_VAPI_ASSISTANT_ID=6cee1a72-ba5c-4239-a8d4-a0cd30b2b547

# 3. Private Key (Backend) - Found in Vapi Dashboard > Account Settings (API Keys)
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# 4. Phone Number ID - Required only for outbound phone call testing (Twilio number ID in Vapi)
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here


# Vercel KV / Redis (Optional, automatically injected by Vercel in production)
# -------------------------------------------------------------
# During local development, if these are empty, the app will gracefully fall back
# to an in-memory database so you can still test it without setting up Redis.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
